{
    "cli": {
        "version": ">= 16.0.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "environment": "development",
            "env": {
                "SENTRY_DISABLE_AUTO_UPLOAD": "true"
            },
            "android": {
                "buildType": "apk"
            },
            "ios": {
                "simulator": true
            }
        },
        "preview": {
            "distribution": "internal",
            "environment": "preview",
            "env": {
                "SENTRY_DISABLE_AUTO_UPLOAD": "true"
            }
        },
        "production": {
            "autoIncrement": true,
            "environment": "production"
        }
    },
    "submit": {
        "production": {}
    }
}

---
import TeamFlag from './team-flag.astro';
---

<section id="top">
    <svg class="motif" viewBox="0 0 900 700" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
        <path
            d="M-40 660 C 240 620, 380 380, 540 250 S 860 40, 980 -20"
            fill="none"
            stroke="var(--border-strong)"
            stroke-width="2"
            stroke-dasharray="2 12"
            stroke-linecap="round"></path>
        <path
            d="M-40 700 C 260 660, 420 420, 600 300 S 900 90, 1020 20"
            fill="none"
            stroke="var(--border-strong)"
            stroke-width="2"
            stroke-dasharray="2 12"
            stroke-linecap="round"
            opacity="0.6"></path>
    </svg>
    <div class="inner">
        <div class="copy">
            <span class="overline"><span class="dot"></span>Pronostics rugby entre potes · Route vers 2027</span>
            <h1>Ton rugby.<br />Tes potes.<br /><span class="spark">Tes pronos.</span></h1>
            <p class="lede">
                L'appli gratuite de pronos pensée <b>pour le rugby</b> — score exact, essais, bonus
                offensif, points pondérés par les cotes. Sans argent réel. 100% entre amis.
            </p>
            <div class="ctas">
                <a class="primary" href="#waitlist">Rejoindre la liste d'attente</a>
                <a class="secondary" href="#concept">Voir le concept</a>
            </div>
            <div class="assurances">
                <span class="item"><span class="check">✓</span>Gratuit</span>
                <span class="sep"></span>
                <span class="item"><span class="check">✓</span>Zéro argent réel</span>
                <span class="sep"></span>
                <span class="item"><span class="check">✓</span>Sortie fév. 2027</span>
            </div>
        </div>
        <div class="phones">
            <div class="fan">
                <div class="phone phone-b">
                    <div class="notch-space"></div>
                    <div class="screen">
                        <div class="screen-overline">Ligue privée</div>
                        <div class="screen-title">Les Potes</div>
                        <div class="board">
                            <div class="row row-plain">
                                <span class="rank">1</span>
                                <span class="avatar avatar-brand">TH</span>
                                <span class="name">Théo</span>
                                <span class="pts">248</span>
                            </div>
                            <div class="row row-you">
                                <span class="rank rank-you">2</span>
                                <span class="avatar avatar-you">TO</span>
                                <span class="name name-you">Toi</span>
                                <span class="pts">241</span>
                            </div>
                            <div class="row">
                                <span class="rank">3</span>
                                <span class="avatar">MK</span>
                                <span class="name">Marek</span>
                                <span class="pts">233</span>
                            </div>
                            <div class="row">
                                <span class="rank">4</span>
                                <span class="avatar">LÉ</span>
                                <span class="name">Léa</span>
                                <span class="pts">220</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="phone phone-a">
                    <div class="statusbar">
                        <span>9:41</span>
                        <span class="battery"></span>
                    </div>
                    <div class="screen">
                        <div class="screen-overline">6 Nations 2027 · J2</div>
                        <div class="screen-title">Mes matchs</div>
                        <div class="match-card">
                            <div class="match-head">
                                <span class="kickoff">21h00</span>
                                <span class="saved"><span class="saved-dot"></span>Enregistré</span>
                            </div>
                            <div class="match-grid">
                                <div class="team">
                                    <TeamFlag abbr="FRA" />
                                    <span>France</span>
                                </div>
                                <div class="score">
                                    <span class="score-box">24</span>
                                    <span class="dash">–</span>
                                    <span class="score-box">18</span>
                                </div>
                                <div class="team">
                                    <TeamFlag abbr="IRL" />
                                    <span>Irlande</span>
                                </div>
                            </div>
                            <div class="match-foot">
                                <span class="bonus"><span class="bonus-dot"></span>Bonus off. FRA</span>
                                <span class="points"><span class="points-num">8</span><span class="points-unit">pts</span></span>
                            </div>
                        </div>
                        <div class="tabbar">
                            <span class="tab-active">Matchs</span>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--text-faint)" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M8.4 12.4l2.4 2.4 4.8-5.2"></path></svg>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--text-faint)" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M6 20V11"></path><path d="M12 20V4"></path><path d="M18 20v-6"></path></svg>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--text-faint)" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="3.6"></circle><path d="M4.5 20c0-3.4 3.4-5.8 7.5-5.8s7.5 2.4 7.5 5.8"></path></svg>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    section {
        position: relative;
        scroll-margin-top: 80px;
        overflow: hidden;
    }

    .motif {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        opacity: 0.5;
    }

    .inner {
        position: relative;
        max-width: 1240px;
        margin: 0 auto;
        padding: 72px 24px 64px;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 48px;
    }

    .copy {
        flex: 1 1 460px;
        min-width: 300px;
    }

    .overline {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--text-faint);
    }

    .dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--accent);
    }

    h1 {
        font-family: var(--font-display);
        font-weight: 400;
        font-size: clamp(52px, 8.5vw, 118px);
        line-height: 0.9;
        letter-spacing: 0.005em;
        margin: 20px 0 0;
        text-wrap: balance;
    }

    .spark {
        color: var(--accent);
    }

    .lede {
        max-width: 480px;
        margin: 26px 0 0;
        font-size: clamp(16px, 2vw, 19px);
        line-height: 1.55;
        color: var(--text-muted);
        text-wrap: pretty;
    }

    .lede b {
        color: var(--text);
    }

    .ctas {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 34px;
    }

    .primary {
        display: inline-flex;
        align-items: center;
        height: 56px;
        padding: 0 30px;
        border-radius: var(--radius-pill);
        background: var(--accent);
        color: var(--on-accent);
        font-size: 16px;
        font-weight: 700;
        box-shadow: var(--glow-accent);
    }

    .primary:hover {
        background: var(--accent-press);
        color: var(--on-accent);
    }

    .secondary {
        display: inline-flex;
        align-items: center;
        height: 56px;
        padding: 0 28px;
        border-radius: var(--radius-pill);
        background: transparent;
        color: var(--text);
        font-size: 16px;
        font-weight: 700;
        border: 1.5px solid var(--border-strong);
    }

    .secondary:hover {
        border-color: var(--text);
        color: var(--text);
    }

    .assurances {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 18px;
        margin-top: 30px;
        font-size: 13px;
        font-weight: 600;
        color: var(--text-faint);
    }

    .item {
        display: inline-flex;
        align-items: center;
        gap: 7px;
    }

    .check {
        color: var(--brand);
        font-size: 16px;
    }

    .sep {
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: var(--border-strong);
    }

    /* ---- Phones fan ---- */
    .phones {
        flex: 1 1 420px;
        min-width: 300px;
        display: flex;
        justify-content: center;
    }

    .fan {
        position: relative;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding: 20px 0;
    }

    .phone {
        flex: none;
        background: var(--surface);
        border: 1px solid var(--border);
        box-shadow: var(--shadow-lg);
        overflow: hidden;
    }

    .phone-b {
        width: 240px;
        transform: rotate(6deg) translateY(30px);
        transform-origin: bottom center;
        border-radius: 38px;
    }

    .phone-b .notch-space {
        height: 26px;
    }

    .phone-b .screen {
        padding: 4px 18px 16px;
    }

    .phone-a {
        width: 250px;
        margin-left: -84px;
        transform: rotate(-5deg);
        transform-origin: bottom center;
        border-radius: 40px;
        position: relative;
        z-index: 2;
    }

    .statusbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 22px 6px;
        font-size: 11px;
        font-weight: 700;
        font-variant-numeric: tabular-nums;
        color: var(--text);
    }

    .battery {
        width: 15px;
        height: 8px;
        border: 1.2px solid var(--text);
        border-radius: 2px;
        opacity: 0.5;
    }

    .phone-a .screen {
        padding: 6px 18px 14px;
    }

    .screen-overline {
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--text-faint);
    }

    .screen-title {
        font-family: var(--font-display);
        font-size: 20px;
        margin-top: 3px;
    }

    /* Classement (phone B) */
    .board {
        display: flex;
        flex-direction: column;
        gap: 7px;
        margin-top: 14px;
    }

    .row {
        display: flex;
        align-items: center;
        gap: 9px;
        padding: 8px 10px;
        border-radius: 11px;
    }

    .row-plain {
        background: var(--surface-sunken);
    }

    .row-you {
        background: color-mix(in srgb, var(--accent) 9%, transparent);
        border: 1.5px solid color-mix(in srgb, var(--accent) 34%, transparent);
    }

    .rank {
        font-family: var(--font-display);
        font-size: 16px;
        width: 16px;
        color: var(--text-faint);
    }

    .rank-you {
        color: var(--accent);
    }

    .avatar {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: var(--surface-sunken);
        color: var(--text-muted);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 9px;
        font-weight: 700;
    }

    .avatar-brand {
        background: var(--brand);
        color: var(--on-brand);
    }

    .avatar-you {
        background: var(--accent);
        color: #fff;
    }

    .name {
        flex: 1;
        font-size: 12px;
        font-weight: 600;
    }

    .name-you {
        font-weight: 700;
        color: var(--accent);
    }

    .pts {
        font-family: var(--font-display);
        font-size: 15px;
        font-variant-numeric: tabular-nums;
    }

    /* Match (phone A) */
    .match-card {
        margin-top: 14px;
        padding: 14px;
        border-radius: 16px;
        background: var(--surface);
        border: 1px solid var(--border);
        box-shadow: var(--shadow-md);
    }

    .match-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .kickoff {
        font-size: 8.5px;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--text-faint);
    }

    .saved {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 3px 8px;
        border-radius: 999px;
        background: color-mix(in srgb, var(--success-500) 14%, transparent);
        color: var(--success-500);
        font-size: 8.5px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .saved-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: var(--success-500);
    }

    .match-grid {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 6px;
        margin-top: 12px;
    }

    .team {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 5px;
    }

    .team span {
        font-size: 10px;
        font-weight: 700;
    }

    .score {
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .score-box {
        width: 34px;
        height: 40px;
        border-radius: 9px;
        background: var(--surface-sunken);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-display);
        font-size: 24px;
        font-variant-numeric: tabular-nums;
    }

    .dash {
        font-family: var(--font-display);
        font-size: 16px;
        color: var(--text-faint);
    }

    .match-foot {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 12px;
        padding-top: 10px;
        border-top: 1px dashed var(--border);
    }

    .bonus {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 9px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--accent);
    }

    .bonus-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: var(--accent);
    }

    .points {
        display: inline-flex;
        align-items: baseline;
        gap: 3px;
        padding: 4px 10px;
        border-radius: 999px;
        background: var(--accent);
        color: var(--on-accent);
    }

    .points-num {
        font-family: var(--font-display);
        font-size: 14px;
    }

    .points-unit {
        font-size: 8px;
        font-weight: 700;
    }

    .tabbar {
        margin: 16px auto 12px;
        width: 92%;
        display: flex;
        align-items: center;
        justify-content: space-around;
        padding: 8px;
        border-radius: 999px;
        background: var(--glass-bar);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid var(--glass-hairline);
        box-shadow: var(--shadow-md);
    }

    .tab-active {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: 30px;
        padding: 0 12px;
        border-radius: 999px;
        background: var(--accent);
        color: var(--on-accent);
        font-size: 9.5px;
        font-weight: 700;
    }
</style>

---
import SectionHeading from './section-heading.astro';

const features = [
    {
        title: 'Pensé pour le rugby',
        body: 'Score exact, essais, bonus offensif, cotes. Les vraies règles du jeu, pas du foot recyclé.',
        paths: ['M12 3c4 2 6 5 6 9s-2 7-6 9c-4-2-6-5-6-9s2-7 6-9z', 'M8 8l8 8', 'M16 8l-8 8'],
    },
    {
        title: 'Ligues privées',
        body: 'Crée ta ligue, invite tes potes avec un simple lien. Votre saison, votre classement.',
        paths: [
            'M9 11a3 3 0 100-6 3 3 0 000 6z',
            'M3 20c0-3 2.7-5 6-5s6 2 6 5',
            'M17 8a3 3 0 010 6',
            'M19 20c0-2-1-3.5-2.5-4.3',
        ],
    },
    {
        title: 'Points malins',
        body: 'Les cotes sont intégrées : plus le pari est audacieux et juste, plus il rapporte de points.',
        paths: ['M4 20V10', 'M10 20V4', 'M16 20v-7', 'M22 20V8'],
    },
    {
        title: 'Classements live',
        body: 'Suis ta place en temps réel — dans ta ligue et au général — au fil des matchs.',
        paths: ['M12 21a9 9 0 100-18 9 9 0 000 18z', 'M12 7v5l3 2'],
    },
    {
        title: 'Multi-compétitions',
        body: '6 Nations, Champions Cup et Coupe du Monde 2027, réunies dans une seule appli.',
        paths: ['M4 6h16', 'M4 12h16', 'M4 18h10'],
    },
    {
        title: 'Gratuit & social',
        body: 'Zéro argent réel, zéro mise, zéro pub déguisée. Juste toi, tes potes et le jeu.',
        paths: [
            'M20.8 5.6a5.5 5.5 0 00-8.8 1 5.5 5.5 0 00-8.8-1 5.5 5.5 0 000 7.8L12 21l8.8-7.6a5.5 5.5 0 000-7.8z',
        ],
    },
];
---

<section>
    <SectionHeading kicker="Le kit" title="Tout ce qu'il te faut" />
    <div class="grid">
        {
            features.map((feature) => (
                <div class="cell">
                    <div class="icon">
                        <svg
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.9"
                            stroke-linecap="round"
                            stroke-linejoin="round">
                            {feature.paths.map((d) => (
                                <path d={d} />
                            ))}
                        </svg>
                    </div>
                    <h3>{feature.title}</h3>
                    <p>{feature.body}</p>
                </div>
            ))
        }
    </div>
</section>

<style>
    section {
        max-width: 1240px;
        margin: 0 auto;
        padding: 0 24px 88px;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 0;
        border-left: 1px solid var(--border);
    }

    .cell {
        padding: 32px 28px;
        border-bottom: 1px solid var(--border);
        border-right: 1px solid var(--border);
        transition: background var(--dur-fast) var(--ease-out);
    }

    .cell:hover {
        background: var(--surface-sunken);
    }

    .icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background: color-mix(in srgb, var(--brand) 10%, transparent);
        color: var(--brand);
        margin-bottom: 18px;
    }

    h3 {
        font-family: var(--font-body);
        font-weight: 700;
        font-size: 18px;
        margin: 0 0 8px;
    }

    p {
        margin: 0;
        font-size: 14.5px;
        line-height: 1.55;
        color: var(--text-muted);
        text-wrap: pretty;
    }
</style>

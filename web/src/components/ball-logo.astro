---
// Ballon TryCast (passe vissée) — même motif SVG que la maquette et le favicon.
interface Props {
    size?: number;
}
const { size = 34 } = Astro.props;
---

<svg width={size} height={size} viewBox="0 0 120 120" aria-hidden="true" style="flex: none;">
    <g transform="rotate(-25 72 54)">
        <line x1="38" y1="54" x2="10" y2="54" stroke="#F06485" stroke-width="6" stroke-linecap="round"
        ></line>
        <line
            x1="40"
            y1="43"
            x2="17"
            y2="43"
            stroke="#F06485"
            stroke-width="4"
            stroke-linecap="round"
            opacity="0.7"></line>
        <line
            x1="40"
            y1="65"
            x2="17"
            y2="65"
            stroke="#F06485"
            stroke-width="4"
            stroke-linecap="round"
            opacity="0.7"></line>
        <ellipse cx="72" cy="54" rx="30" ry="17" fill="#E63E63"></ellipse>
        <line x1="46" y1="54" x2="98" y2="54" stroke="#F1EBDD" stroke-width="2.4" stroke-linecap="round"
        ></line>
        <line x1="56" y1="49.5" x2="56" y2="58.5" stroke="#F1EBDD" stroke-width="2" stroke-linecap="round"
        ></line>
        <line x1="64" y1="48.5" x2="64" y2="59.5" stroke="#F1EBDD" stroke-width="2" stroke-linecap="round"
        ></line>
        <line x1="72" y1="48" x2="72" y2="60" stroke="#F1EBDD" stroke-width="2" stroke-linecap="round"
        ></line>
        <line x1="80" y1="48.5" x2="80" y2="59.5" stroke="#F1EBDD" stroke-width="2" stroke-linecap="round"
        ></line>
        <line x1="88" y1="49.5" x2="88" y2="58.5" stroke="#F1EBDD" stroke-width="2" stroke-linecap="round"
        ></line>
    </g>
</svg>

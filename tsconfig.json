{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
        "strict": true,
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "paths": {
            "@/*": ["./src/*"],
            "@/assets/*": ["./assets/*"]
        }
    },
    "include": [
        "**/*.ts",
        "**/*.tsx",
        ".expo/types/**/*.ts",
        "expo-env.d.ts",
        "nativewind-env.d.ts"
    ],
    "exclude": ["node_modules", "supabase/functions", "web"]
}

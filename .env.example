# Supabase (projet dev : trycast-dev / prod : à créer au Lot 7)
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=sb_publishable_...

# URL du site vitrine (web/) : cible des liens de confirmation d'e-mail Auth.
# Doit figurer dans l'allow-list « Redirect URLs » du projet Supabase.
EXPO_PUBLIC_WEB_URL=https://trycast.fr

# Connexion Google. Ces identifiants sont publics (ils finissent dans le bundle
# de l'app) — le client secret, lui, ne vit que dans le dashboard Supabase.
# Ils sont aussi le SIGNAL D'ACTIVATION du fournisseur : sans eux, le bouton
# « Continuer avec Google » n'est pas rendu et l'app reste utilisable en
# e-mail + mot de passe (c'est ce qui permet à la CI de tourner sans config).
# Le client web est celui que l'app ANDROID utilise — contre-intuitif, mais
# c'est bien la doc Google : le client Android ne sert qu'à la validation par
# empreinte SHA-1.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=<id>.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=<id>.apps.googleusercontent.com

# Télémétrie. Les deux sont FACULTATIVES : sans elles, la mesure d'usage et les
# rapports de plantage sont inertes (aucun envoi), et l'app fonctionne
# normalement — c'est ce qui permet à la CI et à un clone frais de tourner.
#
# Aptabase : la région est encodée dans la clé. Exiger A-EU-... (pas A-US-).
EXPO_PUBLIC_APTABASE_KEY=A-EU-...
# Sentry : l'hôte doit être ...ingest.de.sentry.io (résidence UE). Ce choix se
# fait à la création de l'organisation Sentry et n'est PAS modifiable ensuite.
EXPO_PUBLIC_SENTRY_DSN=https://<clé>@<org>.ingest.de.sentry.io/<projet>
